#!/bin/bash

# Configuration
LOCAL_REPO="$HOME/borg-backups"
KEEPASS_DB="$HOME/Documents/Vault/Vault.kdbx"
REMOTES=("gdrive" "mega-chahat")
ARCHIVE_NAME="keepass-$(date +%F_%H-%M)"
LOCK_FILE="/tmp/sync-passwords.lock"

# 0. Ensure only one instance runs at a time
exec 200>"$LOCK_FILE"
if ! flock -n 200; then
    echo "ERROR: Another instance of sync-passwords is already running."
    exit 1
fi

echo "Starting KeePass database backup process..."

# 1. Create a new encrypted snapshot of the current database
# If the backup generation fails, the script exits cleanly with an error message.
if ! borg create "$LOCAL_REPO::$ARCHIVE_NAME" "$KEEPASS_DB"; then
    echo "CRITICAL ERROR: Failed to create Borg backup snapshot. Exiting."
    exit 1
fi

echo "Borg snapshot created successfully: $ARCHIVE_NAME"

# 2. Prune old backups (Keep 7 daily, 4 weekly, 6 monthly)
if borg prune --keep-daily=7 --keep-weekly=4 --keep-monthly=6 "$LOCAL_REPO"; then
    echo "Borg repository pruned successfully."
else
    echo "Warning: Borg prune encountered an issue, but continuing with sync."
fi

# 3. Mirror the updated local repository to multiple cloud drives
for remote in "${REMOTES[@]}"; do
    echo "Attempting to sync to $remote..."
    # --contimeout: connection timeout
    # --timeout: IO timeout
    # --retries: number of retries if it fails
    # --track-renames: more efficient handling of moved files
    # --fix-case: handles case mismatches across different file systems
    # -P: progress monitoring
    if rclone sync "$LOCAL_REPO" "$remote:BorgBackup" \
       --fast-list \
       --track-renames \
       --fix-case \
       --metadata \
       --contimeout 1m --timeout 5m --retries 3 \
       -P; then
        echo "Successfully synced to $remote."
    else
        echo "CRITICAL ERROR: Failed to sync to $remote. Exiting to prevent further issues."
        exit 1
    fi
done

echo "KeePass backup process completed successfully."
