#!/usr/bin/env bash

# Help menu
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: serve [PORT] [DIRECTORY]"
    echo "Starts a lightweight Python HTTP server."
    echo ""
    echo "  PORT       Port to bind to (default: 8000)"
    echo "  DIRECTORY  Directory to serve (default: .)"
    exit 0
fi

PORT="${1:-8000}"
DIR="${2:-.}"

# Cross-platform IP grabber
IP=$(python3 -c '
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
try:
    # Doesn"t actually send data, just figures out the routing interface
    s.connect(("1.1.1.1", 80))
    print(s.getsockname()[0])
except Exception:
    print("127.0.0.1")
finally:
    s.close()
')

# Display the complete URL
echo -e "Serving \033[1;33m$DIR\033[0m at \033[1;36mhttp://$IP:$PORT\033[0m"

# Execute the server
python3 -m http.server "$PORT" -d "$DIR"
